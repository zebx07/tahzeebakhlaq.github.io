    <div class="footer-links">
      <a href="../privacy-policy.html">Privacy Policy</a>
      <a href="mailto:tahzeebakhlaq26@gmail.com">Contact</a>
      <a href="../">All Apps</a>
    </div>
  </footer>

</body>
</html>
